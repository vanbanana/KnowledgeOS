{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KnowFlow",
  "version": "1.0.0",
  "identifier": "com.knowflow.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm --dir ../.. dev",
    "beforeBuildCommand": "corepack pnpm --dir ../.. build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KnowFlow",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [
      "resources/workers/parser/main.py",
      "resources/workers/parser/requirements.txt",
      "resources/workers/parser/parsers/*.py",
      "resources/migrations/*.sql",
      "resources/prompt-templates/*.md"
    ]
  }
}
